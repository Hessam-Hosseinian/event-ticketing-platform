@startuml
left to right direction
actor Customer
actor Organizer
actor Admin
rectangle Platform {
 usecase "Discover/filter events" as UC1
 usecase "Join waiting room" as UC2
 usecase "Select and lock seats" as UC3
 usecase "Checkout and receive ticket" as UC4
 usecase "Manage venue layout" as UC5
 usecase "Manage events and pricing" as UC6
}
Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC4
Organizer --> UC6
Admin --> UC5
Admin --> UC6
@enduml
